# ============================================================
# College Chatbot - Environment Configuration
# Copy this file to ".env" and fill in your values.
# Only the provider you choose needs to be configured.
# ============================================================

# Which LLM provider to use: "openai" | "gemini" | "ollama" | "nvidia"
LLM_PROVIDER=openai
# Which Embedding provider to use:
#   "sentence-transformers" | "openai" | "gemini" | "ollama" | "nvidia"
EMBEDDING_PROVIDER=sentence-transformers

# ---- OpenAI (or any OpenAI-compatible endpoint) ----
# For inference.net, set OPENAI_BASE_URL to their endpoint.
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Google Gemini ----
GEMINI_API_KEY=your-gemini-key-here
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ---- Ollama (local, no API key needed) ----
# Install from https://ollama.com then run: ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ---- Sentence Transformers (local embeddings, free, no key) ----
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# ---- HuggingFace (for downloading gated/private models from HF Hub) ----
HF_TOKEN=

# ---- NVIDIA NIM (hosted LLM + embeddings, OpenAI-compatible) ----
# Get a key from https://build.nvidia.com.
# The default embedding model is asymmetric: it uses input_type "passage"
# for indexing and "query" for searching.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=z-ai/glm-5.2
NVIDIA_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2

# ============================================================
# Crawler settings
# ============================================================
SITE_URL=https://www.nitsikkim.ac.in
CRAWL_MAX_PAGES=500
CRAWL_DELAY=1.0
CRAWL_USER_AGENT=StellarCollegeBot/1.0 (+college-chatbot)
EXTRA_SEED_URLS=

# ============================================================
# Storage paths
# ============================================================
DATA_DIR=./data
RAW_DIR=./data/raw

# ============================================================
# Pinecone Vector Store
# ============================================================
PINECONE_API_KEY=
PINECONE_INDEX_NAME=college-chatbot

# ============================================================
# API Security
# ============================================================
# Protect the /ingest endpoint (pass as X-Api-Key header).
# Leave blank to allow unauthenticated access (development only).
INGEST_API_KEY=
